# --- DATABASE CONFIG ---
# Required for persistent storage.
# Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://user:password@host/dbname"

# --- EMAIL CONFIG (RESEND) ---
# Required for sending emails and follow-ups.
# Get your API key at https://resend.com
RESEND_API_KEY="re_..."
# Your verified sender email in Resend (default is for testing)
RESEND_FROM_EMAIL="onboarding@resend.dev"

# --- AI CONFIG (OPENAI) ---
# Required for AI email generation features.
OPENAI_API_KEY="sk-..."
# Optional: only if using an OpenAI proxy
OPENAI_BASE_URL=""

# --- APP CONFIG ---
# The URL where your app is hosted (e.g. https://your-app.vercel.app)
APP_URL="MY_APP_URL"
